{
  "manifest_version": 3,
  "name": "JableTV Downloader",
  "version": "1.0.0",
  "description": "Send JableTV & MissAV video URLs to the local downloader app",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": [
    "http://localhost:8088/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.jable.tv/*",
        "*://*.missav.ai/*",
        "*://*.missav.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
